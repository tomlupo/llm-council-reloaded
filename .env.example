# Optional: path to settings JSON (relative to project root or absolute).
# If unset, settings are loaded/saved from backend/data/settings.json.
# Example: copy config/settings.json.example to config/settings.json, then set:
# COUNCIL_SETTINGS_PATH=config/settings.json

# API keys (referenced by api_key_env in settings.json; put keys here or in Settings UI).
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# MINIMAX_API_KEY=
