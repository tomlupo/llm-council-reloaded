{
  "models": [
    {
      "name": "gpt",
      "provider": "openai",
      "model": "gpt-4o",
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "api_key_env": "OPENAI_API_KEY",
      "enabled": true
    },
    {
      "name": "claude",
      "provider": "anthropic",
      "model": "claude-sonnet-4-20250514",
      "endpoint": "https://api.anthropic.com/v1/messages",
      "api_key_env": "ANTHROPIC_API_KEY",
      "enabled": true
    }
  ],
  "model_settings": {
    "max_tokens": 4096,
    "temperature": 0.7,
    "timeout_seconds": 180
  },
  "council": {
    "chairman_strategy": "rotating",
    "chairman_fixed_model": null,
    "peer_review": {
      "enabled": true,
      "anonymize": true,
      "scoring": {
        "criteria": ["accuracy", "completeness", "clarity", "insight"],
        "scale": 10
      }
    },
    "synthesis": {
      "highlight_consensus": true,
      "explain_disagreements": true,
      "include_unique_insights": true
    }
  },
  "default_deliberation_mode": "ask",
  "debate_defaults": { "rounds": 2, "positions": null },
  "decide_defaults": {
    "criteria": ["feasibility", "cost", "complexity", "maintainability"]
  },
  "brainstorm_defaults": { "style": "balanced", "rounds": 2 }
}
